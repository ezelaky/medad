---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeKey?: 'home' | 'news' | 'bestsellers' | 'interviews' | 'reads' | 'banned';
}

const { title, description = 'مِداد — مجلة مستقلة عن الكتب وصناعة النشر في العالم العربي', activeKey } = Astro.props;

const navItems = [
  { href: '/', label: 'الصفحة الرئيسية', key: 'home' },
  { href: '/news/', label: 'أخبار الكتب', key: 'news' },
  { href: '/bestsellers/', label: 'الأكثر مبيعًا', key: 'bestsellers' },
  { href: '/interviews/', label: 'حوارات', key: 'interviews' },
  { href: '/reads/', label: 'ملفات', key: 'reads' },
  { href: '/banned-books/', label: 'الكتب الممنوعة', key: 'banned' },
] as const;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/midad-mark-favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Noto+Naskh+Arabic:wght@400;500;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<header>
  <div class="header-row">
    <button class="search-btn ui" id="searchBtn" aria-label="بحث">
      <svg class="icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      بحث
    </button>
    <div class="logo"><a href="/"><img src="/midad-logo-primary.svg" alt="مِداد" /></a></div>
    <button class="menu-btn" id="menuBtn" aria-label="القائمة">
      <svg class="icon" viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
    </button>
  </div>
  <nav class="cat-nav">
    <ul class="ui">
      {navItems.map((item) => (
        <li><a href={item.href} class={item.key === activeKey ? 'active' : ''}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
  <div class="menu-panel" id="menuPanel">
    <ul class="ui">
      {navItems.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>
    <div class="menu-extra ui">
      <a href="/about/">من نحن</a>
      <a href="/contact/">تواصل معنا</a>
    </div>
  </div>
</header>

<div class="search-panel" id="searchPanel">
  <form class="search-form" id="searchForm">
    <svg class="icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
    <input type="text" id="searchInput" class="ui" placeholder="ابحث في مِداد..." />
  </form>
</div>

<slot />

<footer>
  مِداد © ٢٠٢٦ — مجلة مستقلة عن الكتب وصناعة النشر في العالم العربي
</footer>

<nav class="tab-bar">
  <a href="/" class={activeKey === 'home' ? 'active' : ''}>
    <svg viewBox="0 0 24 24"><path d="M3 11l9-8 9 8M5 10v10h14V10"/></svg>
    الرئيسية
  </a>
  <a href="#">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    الأقسام
  </a>
  <a href="#">
    <svg viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 00-7.8 0L12 5.6l-1-1a5.5 5.5 0 10-7.8 7.8L12 21l8.8-8.6a5.5 5.5 0 000-7.8z"/></svg>
    المفضلة
  </a>
  <a href="#">
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
    البحث
  </a>
</nav>

<script>
  const searchBtn = document.getElementById('searchBtn');
  const menuBtn = document.getElementById('menuBtn');
  const searchPanel = document.getElementById('searchPanel');
  const menuPanel = document.getElementById('menuPanel');
  const searchInput = document.getElementById('searchInput');
  const searchForm = document.getElementById('searchForm');

  searchForm?.addEventListener('submit', (e) => e.preventDefault());

  searchBtn?.addEventListener('click', () => {
    searchPanel?.classList.toggle('open');
    menuPanel?.classList.remove('open');
    setTimeout(() => (searchInput as HTMLInputElement)?.focus(), 50);
  });

  menuBtn?.addEventListener('click', () => {
    menuPanel?.classList.toggle('open');
    searchPanel?.classList.remove('open');
  });
</script>

<style>
  .header-row {
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    padding: 20px 6vw; border-bottom: 1px solid var(--line);
  }
  .search-btn {
    justify-self: start; display: flex; align-items: center; gap: 8px;
    background: none; border: none; color: var(--ink-soft); font-family: 'IBM Plex Sans Arabic', sans-serif;
    font-size: 0.88rem; cursor: pointer; padding: 0;
  }
  .logo { justify-self: center; }
  .logo img { height: 2.6rem; display: block; }
  .menu-btn { justify-self: end; background: none; border: none; cursor: pointer; padding: 0; }
  .icon { width: 20px; height: 20px; stroke: var(--ink); fill: none; stroke-width: 1.6; }
  header { position: relative; }

  .cat-nav { border-bottom: 1px solid var(--line); }
  .cat-nav ul { list-style: none; display: flex; justify-content: center; gap: 32px; margin: 0; padding: 14px 6vw; }
  .cat-nav a {
    text-decoration: none; color: var(--ink-soft); font-size: 0.9rem; font-family: 'IBM Plex Sans Arabic', sans-serif;
    padding-bottom: 12px; border-bottom: 2px solid transparent; margin-bottom: -15px;
  }
  .cat-nav a.active { color: var(--crimson); border-color: var(--crimson); font-weight: 600; }
  .cat-nav a:hover { color: var(--crimson); }

  .tab-bar { display: none; }

  .search-panel { max-height: 0; overflow: hidden; transition: max-height .3s ease; border-bottom: 1px solid var(--line); }
  .search-panel.open { max-height: 90px; }
  .search-form { display: flex; align-items: center; gap: 12px; padding: 22px 6vw; max-width: 700px; margin: 0 auto; }
  .search-form input { flex: 1; border: none; background: none; font-size: 1.05rem; font-family: inherit; outline: none; color: var(--ink); }
  .search-form .icon { flex-shrink: 0; }

  .menu-panel {
    position: absolute; top: 100%; left: 6vw; width: 230px; z-index: 30;
    max-height: 0; overflow: hidden; opacity: 0;
    background: var(--card); border: 1px solid var(--line); border-radius: 6px;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.10);
    transition: max-height .3s ease, opacity .25s ease;
  }
  .menu-panel.open { max-height: 420px; opacity: 1; }
  .menu-panel ul { list-style: none; margin: 0; padding: 8px 18px; }
  .menu-panel ul li { border-bottom: 1px solid var(--line); }
  .menu-panel ul li:last-child { border-bottom: none; }
  .menu-panel ul a {
    display: block; padding: 11px 0; text-decoration: none; color: var(--ink); font-family: 'IBM Plex Sans Arabic', sans-serif;
    font-size: 0.9rem;
  }
  .menu-panel ul a:hover { color: var(--crimson); }
  .menu-extra { padding: 10px 18px 14px; display: flex; flex-direction: column; gap: 8px; border-top: 1px solid var(--line); }
  .menu-extra a { color: var(--ink-soft); text-decoration: none; font-size: 0.82rem; }
  .menu-extra a:hover { color: var(--crimson); }

  footer { padding: 5vh 6vw; text-align: center; font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.8rem; color: var(--ink-soft); border-top: 1px solid var(--line); }

  @media (max-width: 900px) {
    .cat-nav { display: none; }
    :global(body) { padding-bottom: 64px; }
    .tab-bar {
      display: flex; position: fixed; bottom: 0; right: 0; left: 0; z-index: 20;
      background: var(--card); border-top: 1px solid var(--line);
      justify-content: space-around; padding: 10px 0 8px;
    }
    .tab-bar a {
      display: flex; flex-direction: column; align-items: center; gap: 4px; text-decoration: none;
      color: var(--ink-soft); font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.68rem;
    }
    .tab-bar a.active { color: var(--crimson); }
    .tab-bar svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.7; }
  }
</style>
</body>
</html>
