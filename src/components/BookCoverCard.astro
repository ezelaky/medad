---
interface Props {
  /** omit for rank variant to render a non-interactive card — no bestseller detail page exists yet */
  href?: string;
  coverSrc?: string;
  coverAlt?: string;
  title: string;
  variant: 'rank' | 'browse';
  // rank variant (bestsellers.astro)
  rank?: number;
  titleArabic?: string;
  titleOriginal?: string;
  author?: string;
  publisher?: string;
  description?: string;
  trend?: 'new' | 'up' | 'down' | 'same';
  weeksOnList?: string;
  // browse variant (banned-books archive grid)
  tagText?: string;
}

const trendGlyph = { new: '★', up: '↑', down: '↓', same: '–' };
const arabicDigits = new Intl.NumberFormat('ar-EG-u-nu-arab');

const {
  href, coverSrc, coverAlt = '', title, variant,
  rank, titleArabic, titleOriginal, author, publisher, description, trend, weeksOnList,
  tagText,
} = Astro.props;

const RankTag = href ? 'a' : 'div';
---

{variant === 'rank' && (
  <RankTag {...(href ? { href } : {})} class="rank-card">
    <div class="rank-cover ui">
      {coverSrc ? <img src={coverSrc} alt={coverAlt} /> : title}
      <div class="rank-badge">
        <span class="badge-rank display-sm">{rank !== undefined && arabicDigits.format(rank)}</span>
        {trend && <span class:list={['badge-trend', trend]}>{trendGlyph[trend]}</span>}
        {weeksOnList && <span class="badge-weeks">{weeksOnList}</span>}
      </div>
    </div>
    <div class="rank-info">
      <h3 class="title-ar">{titleArabic || <span class="pending ui">بانتظار الترجمة</span>}</h3>
      {titleOriginal && <p class="title-en ui" dir="ltr">{titleOriginal}</p>}
      <p class="byline ui">{[author, publisher].filter(Boolean).join(' — ')}</p>
      {description && <p class="desc ui">{description}</p>}
    </div>
  </RankTag>
)}

{variant === 'browse' && (
  <a href={href} class="browse-card">
    <div class="cover ui">{coverSrc ? <img src={coverSrc} alt={coverAlt} /> : title}</div>
    <div class="meta">
      <h3>{title}</h3>
      <span class="tag ui">{tagText}</span>
    </div>
  </a>
)}

<style>
  a, .rank-card { text-decoration: none; color: inherit; display: block; }

  /* rank variant — bestsellers.astro card grid */
  .rank-card {
    display: flex; gap: 16px; align-items: flex-start;
    background: var(--card); border: 1px solid var(--line); border-radius: 4px; padding: 14px;
  }
  .rank-cover {
    position: relative; flex: 0 0 150px; aspect-ratio: 3 / 4.2; border-radius: 2px; overflow: hidden;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem; color: var(--ink-soft); text-align: center;
  }
  .rank-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .rank-badge {
    position: absolute; top: 8px; inset-inline-start: 8px;
    background: var(--paper); border-radius: 3px; padding: 3px 6px;
    display: flex; align-items: center; gap: 4px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    line-height: 1;
  }
  .badge-rank { font-size: 1rem; color: var(--crimson); }
  .badge-trend { font-size: 0.7rem; }
  .badge-trend.new { color: var(--brass); }
  .badge-trend.up { color: #3d7a4d; }
  .badge-trend.down { color: var(--crimson); }
  .badge-trend.same { color: var(--ink-soft); }
  .badge-weeks { font-size: 0.6rem; color: var(--ink-soft); }

  .rank-info { flex: 1; min-width: 0; }
  .rank-info .title-ar { font-size: 1.05rem; font-weight: 700; margin: 0 0 2px; }
  .rank-info .title-ar .pending { font-size: 0.75rem; font-weight: 500; color: var(--brass); }
  .rank-info .title-en {
    margin: 0 0 8px; font-size: 0.82rem; font-style: italic; color: var(--ink-soft); text-align: left;
  }
  .rank-info .byline { margin: 0 0 6px; font-size: 0.8rem; color: var(--ink-soft); }
  .rank-info .desc {
    margin: 0; font-size: 0.8rem; color: var(--ink-soft); line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* browse variant — banned-books/index.astro .browse-card */
  .browse-card { background: var(--card); border: 1px solid var(--line); }
  .browse-card .cover {
    aspect-ratio: 3 / 4.2; overflow: hidden;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.72rem; color: var(--ink-soft);
  }
  .browse-card .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .browse-card .meta { padding: 12px 14px; }
  .browse-card h3 { font-size: 0.92rem; margin: 0 0 4px; }
  .browse-card .tag { font-size: 0.72rem; color: var(--brass); }
</style>
