---
interface Props {
  attribution?: string;
}
const { attribution } = Astro.props;
---

<div class="pull-quote display">
  <slot />
  {attribution && <span class="ui">{attribution}</span>}
</div>

<style>
  .pull-quote {
    border-right: 3px solid var(--crimson); padding: 6px 26px; margin: 44px 0;
    font-size: 1.5rem; color: var(--ink);
  }
  .pull-quote span { display: block; font-size: 0.8rem; color: var(--brass); margin-top: 10px; }
</style>
