---
interface Props {
  href: string;
  coverSrc?: string;
  coverAlt?: string;
  coverPlaceholder?: string;
  tag?: string;
  title: string;
  meta: string;
  /** 'latest' = index.html's square-cover card; 'news' = news.html's bordered card */
  variant?: 'latest' | 'news';
}

const { href, coverSrc, coverAlt = '', coverPlaceholder = 'صورة', tag, title, meta, variant = 'latest' } = Astro.props;
---

{variant === 'news' ? (
  <a href={href} class="article-card news">
    <div class="cover ui">{coverSrc ? <img src={coverSrc} alt={coverAlt} /> : coverPlaceholder}</div>
    <div class="body">
      <h3>{title}</h3>
      <p class="ui">{meta}</p>
    </div>
  </a>
) : (
  <a href={href} class="article-card latest">
    <div class="cover ui">{coverSrc ? <img src={coverSrc} alt={coverAlt} /> : coverPlaceholder}</div>
    {tag && <div class="tag ui">{tag}</div>}
    <h3 class="display-sm">{title}</h3>
    <div class="meta">{meta}</div>
  </a>
)}

<style>
  .article-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* latest variant — index.html .latest-card */
  .article-card.latest .cover {
    aspect-ratio: 1 / 1;
    background: linear-gradient(150deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; color: var(--ink-soft);
    margin-bottom: 12px; overflow: hidden;
  }
  .article-card.latest .tag {
    color: var(--crimson); font-size: 0.78rem; font-weight: 600; margin-bottom: 6px;
  }
  .article-card.latest h3 {
    font-size: 0.95rem; margin: 0 0 8px; line-height: 1.6;
  }
  .article-card.latest .meta {
    font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.75rem; color: var(--ink-soft);
  }

  /* news variant — news.html .news-card */
  .article-card.news {
    background: var(--card); border: 1px solid var(--line);
  }
  .article-card.news .cover {
    aspect-ratio: 16 / 11;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.72rem; color: var(--ink-soft);
    overflow: hidden;
  }
  .article-card.news .body {
    padding: 14px;
  }
  .article-card.news h3 {
    font-size: 0.95rem; margin: 0 0 6px; line-height: 1.6;
  }
  .article-card.news .body p {
    margin: 0; font-size: 0.78rem; color: var(--ink-soft);
  }

  .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
