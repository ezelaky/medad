---
import { client, queries, imageUrl } from '../lib/sanity';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { formatArabicDate } from '../lib/formatDate';

const [articles, interviews, longReads, bestsellers, homepage, homeInterviews, homeLongReads, homeBannedBooks] = await Promise.all([
  client.fetch(queries.articles),
  client.fetch(queries.interviews),
  client.fetch(queries.longReads),
  client.fetch(queries.homeBestsellers),
  client.fetch(queries.homepage),
  client.fetch(queries.homeInterviews),
  client.fetch(queries.homeLongReads),
  client.fetch(queries.homeBannedBooks),
]);

// heroItems can mix article/interview/longRead/bannedBookEntry — resolve
// each to a common shape by _type rather than assuming one content type.
const routePrefixes: Record<string, string> = {
  article: '/news/',
  interview: '/interviews/',
  longRead: '/reads/',
  bannedBookEntry: '/banned-books/',
};

const scrimOpacity: Record<string, number> = { light: 0.35, medium: 0.55, strong: 0.75 };

function resolveHeroItem(heroItem: any) {
  const item = heroItem.content;
  return {
    href: `${routePrefixes[item._type]}${item.id}/`,
    title: item.title ?? item.bookTitle,
    cover: imageUrl(item.coverImage ?? item.portraitImage, 1600),
    scrimOpacity: scrimOpacity[heroItem.scrimStrength] ?? scrimOpacity.medium,
  };
}

// Filters out entries whose reference didn't resolve — e.g. left over from
// the previous plain-reference heroItems shape, or a reference to an
// unpublished/deleted document.
const heroItems: any[] = (homepage?.heroItems ?? []).filter((h: any) => h?.content);
const heroSlide = heroItems[0] ? resolveHeroItem(heroItems[0]) : null;

// Homepage "أحدث المقالات" pulls the most recent items across every content
// type — mirrors the original mockup's mixed tags (أدب / حوارات / كتب ممنوعة / تقارير).
const latest = [
  ...articles.map((e: any) => ({ href: `/news/${e.id}/`, tag: e.category, title: e.title, date: e.publishedAt, cover: imageUrl(e.coverImage, 400) })),
  ...interviews.map((e: any) => ({ href: `/interviews/${e.id}/`, tag: 'حوارات', title: e.title, date: e.publishedAt, cover: imageUrl(e.portraitImage, 400) })),
  ...longReads.map((e: any) => ({ href: `/reads/${e.id}/`, tag: 'قراءات مطوّلة', title: e.title, date: e.publishedAt, cover: imageUrl(e.coverImage, 400) })),
]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 5);

// Four homepage strips below أحدث المقالات, all rendered with the same
// ArticleCard "latest" pattern that section already uses — normalized to
// one {href, tag, title, meta, cover} shape per strip so the template
// below doesn't need to branch per content type.
const interviewCards = homeInterviews.map((e: any) => ({
  href: `/interviews/${e.slug.current}/`,
  tag: 'حوارات',
  title: e.title,
  meta: formatArabicDate(new Date(e.publishedAt)),
  cover: imageUrl(e.coverImage, 400),
}));

const longReadCards = homeLongReads.map((e: any) => ({
  href: `/reads/${e.slug.current}/`,
  tag: 'قراءات مطوّلة',
  title: e.title,
  meta: formatArabicDate(new Date(e.publishedAt)),
  cover: imageUrl(e.coverImage, 400),
}));

const bannedBookCards = homeBannedBooks.map((e: any) => ({
  href: `/banned-books/${e.slug.current}/`,
  tag: 'كتب ممنوعة',
  title: e.bookTitle,
  meta: `${e.year} — ${e.country}`,
  cover: imageUrl(e.coverImage, 400),
}));

// Already ordered and capped at 5 by queries.homeBestsellers (nonfiction,
// then fiction, by rank) — no client-side sort/slice needed. No per-entry
// page exists yet (see BookCoverCard.astro's rank-variant comment), so
// every card points at the section index rather than a real detail route.
const arabicDigits = new Intl.NumberFormat('ar-EG-u-nu-arab');
const bestsellerCards = bestsellers.map((e: any) => ({
  href: '/bestsellers/',
  title: e.titleArabic,
  author: e.author,
  rank: arabicDigits.format(e.rank),
  cover: imageUrl(e.coverImage, 300),
}));
---

<BaseLayout title="مِداد — أخبار الكتب وثقافة النشر" activeKey="home">

{heroSlide ? (
  <div class="hero-wrap">
    <div class="hero" style={`--scrim-opacity: ${heroSlide.scrimOpacity}`}>
      {heroSlide.cover ? (
        <img class="hero-image" src={heroSlide.cover} alt="" />
      ) : (
        <div class="hero-image hero-placeholder ui">صورة</div>
      )}
      <div class="hero-scrim"></div>
      <div class="hero-text">
        <div class="hero-tag ui">مقال رئيسي</div>
        <h1 class="display-lg"><a href={heroSlide.href}>{heroSlide.title}</a></h1>
      </div>
    </div>
    {heroItems.length > 1 && (
      <div class="dots">
        {heroItems.map((_, i) => <span class={i === 0 ? 'active' : ''}></span>)}
      </div>
    )}
  </div>
) : (
  <p class="page-intro ui">لم يتم اختيار عناصر للصفحة الرئيسية بعد.</p>
)}

<section class="latest">
  <div class="section-head">
    <h2>أحدث المقالات</h2>
    <a href="/news/">عرض الكل ←</a>
  </div>
  <div class="latest-grid">
    {latest.length > 0 ? latest.map((item) => (
      <ArticleCard
        variant="latest"
        href={item.href}
        coverSrc={item.cover}
        tag={item.tag}
        title={item.title}
        meta={formatArabicDate(new Date(item.date))}
      />
    )) : <p class="ui empty-note">لا يوجد محتوى منشور بعد.</p>}
  </div>
</section>

<section class="home-strip">
  <div class="section-head">
    <h2>حوارات</h2>
    <a href="/interviews/">عرض الكل ←</a>
  </div>
  <div class="strip-grid">
    {interviewCards.length > 0 ? interviewCards.map((item) => (
      <ArticleCard variant="latest" href={item.href} coverSrc={item.cover} tag={item.tag} title={item.title} meta={item.meta} />
    )) : <p class="ui empty-note">لا يوجد محتوى منشور بعد.</p>}
  </div>
</section>

<section class="home-strip">
  <div class="section-head">
    <h2>ملفات</h2>
    <a href="/reads/">عرض الكل ←</a>
  </div>
  <div class="strip-grid">
    {longReadCards.length > 0 ? longReadCards.map((item) => (
      <ArticleCard variant="latest" href={item.href} coverSrc={item.cover} tag={item.tag} title={item.title} meta={item.meta} />
    )) : <p class="ui empty-note">لا يوجد محتوى منشور بعد.</p>}
  </div>
</section>

<section class="home-strip">
  <div class="section-head">
    <h2>الكتب الممنوعة</h2>
    <a href="/banned-books/">عرض الكل ←</a>
  </div>
  <div class="strip-grid">
    {bannedBookCards.length > 0 ? bannedBookCards.map((item) => (
      <ArticleCard variant="latest" href={item.href} coverSrc={item.cover} tag={item.tag} title={item.title} meta={item.meta} />
    )) : <p class="ui empty-note">لا يوجد محتوى منشور بعد.</p>}
  </div>
</section>

<section class="home-strip">
  <div class="section-head">
    <h2>الأكثر مبيعًا</h2>
    <a href="/bestsellers/">عرض الكل ←</a>
  </div>
  <div class="bestseller-grid">
    {bestsellerCards.length > 0 ? bestsellerCards.map((item) => (
      <a href={item.href} class="bestseller-card">
        <div class="cover ui">
          {item.cover ? <img src={item.cover} alt="" /> : 'صورة'}
          <span class="rank">{item.rank}</span>
        </div>
        <h3 class="title">{item.title}</h3>
        <p class="author ui">{item.author}</p>
      </a>
    )) : <p class="ui empty-note">لا يوجد قائمة منشورة بعد.</p>}
  </div>
</section>

</BaseLayout>

<style>
  .hero-wrap { max-width: 1300px; margin: 0 auto; padding: 5vh 6vw 3vh; }
  .hero {
    position: relative;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    background: var(--paper);
    border: 1px solid var(--line);
  }
  .hero-image {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .hero-placeholder {
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(150deg, #e7e0d1, #d8cfba);
    color: var(--ink-soft); font-size: 0.85rem;
  }
  /* always-on gradient — every hero image gets it, regardless of brightness;
     --scrim-opacity is set per-slide from the CMS (light/medium/strong).
     Reaches most of the frame's height (not just the bottom corner) so text
     stays legible even over a busy/detailed part of the image, not just a
     plain-wash area — full opacity at the bottom, half that through the
     middle, clear only in the top ~15%. */
  .hero-scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(23, 20, 15, var(--scrim-opacity)) 0%,
      rgba(23, 20, 15, calc(var(--scrim-opacity) * 0.55)) 45%,
      transparent 85%
    );
  }
  .hero-text {
    position: absolute; inset: auto 0 0 0;
    padding: 5vh 5vw 6vh;
    text-align: right;
  }
  .hero-tag { color: var(--red); font-size: 0.85rem; font-weight: 600; margin-bottom: 14px; }
  .hero-text h1 {
    color: var(--paper); font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.5;
    margin: 0; max-width: 640px;
  }
  /* the title is the hero's only interactive element (no summary, no
     button) — underline + slight opacity dip on hover is the only
     affordance signaling it's clickable */
  .hero-text h1 a {
    color: inherit; text-decoration: none; transition: opacity 0.2s ease;
  }
  .hero-text h1 a:hover { text-decoration: underline; opacity: 0.85; }

  .dots { display: flex; justify-content: center; gap: 7px; margin-top: 20px; }
  .dots span { width: 6px; height: 6px; border-radius: 50%; background: var(--line); }
  .dots span.active { background: var(--red); }

  .latest { max-width: 1300px; margin: 0 auto; padding: 2vh 6vw 6vh; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--line); padding-bottom: 14px; margin-bottom: 26px; }
  .section-head h2 { font-size: 1.2rem; margin: 0; font-family: 'IBM Plex Sans Arabic', sans-serif; font-weight: 600; }
  .section-head a { font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.82rem; color: var(--ink-soft); text-decoration: none; }
  .latest-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  .empty-note { grid-column: 1 / -1; color: var(--ink-soft); font-size: 0.9rem; }

  /* Four strips below أحدث المقالات (حوارات / ملفات / الكتب الممنوعة /
     الأكثر مبيعًا) — same section-head + card-grid pattern as .latest
     above, just 3 columns instead of 5 to match "latest 3 items" instead
     of "latest 5". Reuses ArticleCard's "latest" variant directly. */
  .home-strip { max-width: 1300px; margin: 0 auto; padding: 2vh 6vw 6vh; }
  .strip-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

  /* الأكثر مبيعًا strip only — a compact shelf row, not the feature-card
     pattern above. Fixed 130px card width (not stretched to the grid
     column) keeps covers thumbnail-sized even at wide viewports; the
     aspect-ratio (13/18) is chosen so that width lands the cover height
     right at the ~180px target on desktop, and scales down with it at the
     120px mobile width instead of needing a second fixed height. */
  .bestseller-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
  .bestseller-card {
    display: block; width: 130px; justify-self: center;
    text-decoration: none; color: inherit;
  }
  .bestseller-card .cover {
    position: relative; width: 100%; aspect-ratio: 13 / 18;
    border-radius: 2px; overflow: hidden;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem; color: var(--ink-soft);
    margin-bottom: 8px;
  }
  .bestseller-card .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .bestseller-card .rank {
    position: absolute; top: 6px; inset-inline-start: 6px;
    background: var(--paper); color: var(--brass); font-weight: 700;
    font-size: 0.75rem; border-radius: 3px; padding: 2px 6px; line-height: 1.2;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }
  .bestseller-card .title {
    font-size: 0.85rem; margin: 0 0 4px; line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .bestseller-card .author {
    font-size: 0.72rem; color: var(--ink-soft); margin: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  @media (max-width: 1024px) {
    .bestseller-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 767px) {
    .bestseller-grid {
      display: flex; overflow-x: auto; gap: 1rem;
      scrollbar-width: none; -webkit-overflow-scrolling: touch;
    }
    .bestseller-grid::-webkit-scrollbar { display: none; }
    .bestseller-card { flex: 0 0 120px; width: 120px; }
  }

  @media (max-width: 900px) {
    .hero { aspect-ratio: 4 / 5; }
    .hero-text { padding: 4vh 6vw 5vh; }
    .hero-text h1, .hero-text p.lead { max-width: none; }
    .latest-grid { grid-template-columns: repeat(2, 1fr); }
    .strip-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .strip-grid { grid-template-columns: 1fr; }
  }
</style>
