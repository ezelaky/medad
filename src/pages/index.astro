---
import { client, queries, imageUrl } from '../lib/sanity';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { formatArabicDate } from '../lib/formatDate';

const [articles, interviews, longReads, bestsellers, homepage] = await Promise.all([
  client.fetch(queries.articles),
  client.fetch(queries.interviews),
  client.fetch(queries.longReads),
  client.fetch(queries.bestsellerEntries),
  client.fetch(queries.homepage),
]);

// heroItems can mix article/interview/longRead/bannedBookEntry — resolve
// each to a common shape by _type rather than assuming one content type.
const routePrefixes: Record<string, string> = {
  article: '/news/',
  interview: '/interviews/',
  longRead: '/reads/',
  bannedBookEntry: '/banned-books/',
};

const scrimOpacity: Record<string, number> = { light: 0.35, medium: 0.55, strong: 0.75 };

function resolveHeroItem(heroItem: any) {
  const item = heroItem.content;
  return {
    href: `${routePrefixes[item._type]}${item.id}/`,
    title: item.title ?? item.bookTitle,
    excerpt: item.excerpt ?? item.dek ?? item.summary,
    cover: imageUrl(item.coverImage ?? item.portraitImage, 1600),
    date: item.publishedAt,
    scrimOpacity: scrimOpacity[heroItem.scrimStrength] ?? scrimOpacity.medium,
  };
}

// Filters out entries whose reference didn't resolve — e.g. left over from
// the previous plain-reference heroItems shape, or a reference to an
// unpublished/deleted document.
const heroItems: any[] = (homepage?.heroItems ?? []).filter((h: any) => h?.content);
const heroSlide = heroItems[0] ? resolveHeroItem(heroItems[0]) : null;

// Homepage "أحدث المقالات" pulls the most recent items across every content
// type — mirrors the original mockup's mixed tags (أدب / حوارات / كتب ممنوعة / تقارير).
const latest = [
  ...articles.map((e: any) => ({ href: `/news/${e.id}/`, tag: e.category, title: e.title, date: e.publishedAt, cover: imageUrl(e.coverImage, 400) })),
  ...interviews.map((e: any) => ({ href: `/interviews/${e.id}/`, tag: 'حوارات', title: e.title, date: e.publishedAt, cover: imageUrl(e.portraitImage, 400) })),
  ...longReads.map((e: any) => ({ href: `/reads/${e.id}/`, tag: 'قراءات مطوّلة', title: e.title, date: e.publishedAt, cover: imageUrl(e.coverImage, 400) })),
]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 5);

const longReadFeat = [...longReads].sort(
  (a: any, b: any) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
)[0];
const newBooks = [...bestsellers].sort((a: any, b: any) => a.rank - b.rank).slice(0, 4);
---

<BaseLayout title="مِداد — أخبار الكتب وثقافة النشر" activeKey="home">

{heroSlide ? (
  <div class="hero-wrap">
    <div class="hero" style={`--scrim-opacity: ${heroSlide.scrimOpacity}`}>
      {heroSlide.cover ? (
        <img class="hero-image" src={heroSlide.cover} alt="" />
      ) : (
        <div class="hero-image hero-placeholder ui">صورة</div>
      )}
      <div class="hero-scrim"></div>
      <div class="hero-text">
        <div class="hero-tag ui">مقال رئيسي</div>
        <h1 class="display-lg">{heroSlide.title}</h1>
        {heroSlide.excerpt && <p class="lead">{heroSlide.excerpt}</p>}
        {heroSlide.date && (
          <div class="hero-byline ui">بقلم: فريق التحرير &nbsp; {formatArabicDate(new Date(heroSlide.date))}</div>
        )}
        <a class="read-more" href={heroSlide.href}>
          اقرأ المزيد
          <svg viewBox="0 0 24 24"><path d="M14 6l-6 6 6 6"/></svg>
        </a>
      </div>
    </div>
    {heroItems.length > 1 && (
      <div class="dots">
        {heroItems.map((_, i) => <span class={i === 0 ? 'active' : ''}></span>)}
      </div>
    )}
  </div>
) : (
  <p class="page-intro ui">لم يتم اختيار عناصر للصفحة الرئيسية بعد.</p>
)}

<section class="latest">
  <div class="section-head">
    <h2>أحدث المقالات</h2>
    <a href="/news/">عرض الكل ←</a>
  </div>
  <div class="latest-grid">
    {latest.length > 0 ? latest.map((item) => (
      <ArticleCard
        variant="latest"
        href={item.href}
        coverSrc={item.cover}
        tag={item.tag}
        title={item.title}
        meta={formatArabicDate(new Date(item.date))}
      />
    )) : <p class="ui empty-note">لا يوجد محتوى منشور بعد.</p>}
  </div>
</section>

<section class="trio">
  {longReadFeat && (
    <div class="trio-col longread-feat">
      <div class="section-head"><h2>قراءات طويلة</h2><a href="/reads/">عرض الكل ←</a></div>
      <a href={`/reads/${longReadFeat.id}/`}>
        <div class="cover ui">{longReadFeat.coverImage ? <img src={imageUrl(longReadFeat.coverImage, 600)} alt="" /> : 'صورة'}</div>
        <h3 class="display-sm">{longReadFeat.title}</h3>
        <p>{longReadFeat.dek}</p>
      </a>
    </div>
  )}

  <div class="trio-col">
    <div class="section-head"><h2>كتب جديدة</h2><a href="/bestsellers/">عرض الكل ←</a></div>
    <div class="books-grid">
      {newBooks.map((book: any) => (
        <div class="cover">{book.coverImage && <img src={imageUrl(book.coverImage, 300)} alt="" />}</div>
      ))}
    </div>
    <h4 class="display-sm">كل ما صدر حديثًا</h4>
    <p class="desc">رواية، دراسة، شعر، سيرة...</p>
  </div>

  <div class="trio-col voices">
    <div class="section-head"><h2>أصوات من العالم</h2><a href="#">عرض الكل ←</a></div>
    <div class="cover">صورة</div>
    <h4 class="display-sm">هل تنجو الصحافة الثقافية في الغرب؟</h4>
    <p class="desc">قراءة في مستقبل المجلات الأدبية والثقافية</p>
  </div>
</section>

</BaseLayout>

<style>
  .hero-wrap { max-width: 1300px; margin: 0 auto; padding: 5vh 6vw 3vh; }
  .hero {
    position: relative;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    background: var(--paper);
    border: 1px solid var(--line);
  }
  .hero-image {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .hero-placeholder {
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(150deg, #e7e0d1, #d8cfba);
    color: var(--ink-soft); font-size: 0.85rem;
  }
  /* always-on gradient — every hero image gets it, regardless of brightness;
     --scrim-opacity is set per-slide from the CMS (light/medium/strong).
     Reaches most of the frame's height (not just the bottom corner) so text
     stays legible even over a busy/detailed part of the image, not just a
     plain-wash area — full opacity at the bottom, half that through the
     middle, clear only in the top ~15%. */
  .hero-scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(23, 20, 15, var(--scrim-opacity)) 0%,
      rgba(23, 20, 15, calc(var(--scrim-opacity) * 0.55)) 45%,
      transparent 85%
    );
  }
  .hero-text {
    position: absolute; inset: auto 0 0 0;
    padding: 5vh 5vw 6vh;
    text-align: right;
  }
  .hero-tag { color: var(--red); font-size: 0.85rem; font-weight: 600; margin-bottom: 14px; }
  .hero-text h1 {
    color: var(--paper); font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.5;
    margin: 0 0 14px; max-width: 640px;
  }
  .hero-text p.lead { color: rgba(246, 242, 233, 0.88); font-size: 1rem; margin: 0 0 16px; max-width: 600px; }
  .hero-byline { font-size: 0.82rem; color: rgba(246, 242, 233, 0.75); margin-bottom: 16px; }
  .read-more {
    display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: var(--paper);
    font-family: 'IBM Plex Sans Arabic', sans-serif; font-weight: 600; font-size: 0.9rem; width: fit-content;
  }
  .read-more svg { width: 16px; height: 16px; stroke: var(--paper); fill: none; stroke-width: 1.8; }

  .dots { display: flex; justify-content: center; gap: 7px; margin-top: 20px; }
  .dots span { width: 6px; height: 6px; border-radius: 50%; background: var(--line); }
  .dots span.active { background: var(--red); }

  .latest { max-width: 1300px; margin: 0 auto; padding: 2vh 6vw 6vh; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--line); padding-bottom: 14px; margin-bottom: 26px; }
  .section-head h2 { font-size: 1.2rem; margin: 0; font-family: 'IBM Plex Sans Arabic', sans-serif; font-weight: 600; }
  .section-head a { font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.82rem; color: var(--ink-soft); text-decoration: none; }
  .latest-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  .empty-note { grid-column: 1 / -1; color: var(--ink-soft); font-size: 0.9rem; }

  .trio { max-width: 1300px; margin: 0 auto; padding: 2vh 6vw 10vh; display: grid; grid-template-columns: 1.3fr 1fr 1fr; gap: 32px; }
  .trio-col .section-head { font-size: 1.05rem; }
  .trio-col > a { text-decoration: none; color: inherit; display: block; }
  .longread-feat .cover {
    aspect-ratio: 16 / 10; background: linear-gradient(150deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem; color: var(--ink-soft); margin-bottom: 16px; overflow: hidden;
  }
  .longread-feat .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .longread-feat h3 { font-size: 1.15rem; margin: 0 0 8px; }
  .longread-feat p { font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.85rem; color: var(--ink-soft); margin: 0; }

  .books-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 16px; }
  .books-grid .cover {
    aspect-ratio: 3 / 4.3; background: linear-gradient(150deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .books-grid .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .trio-col h4 { font-size: 1rem; margin: 0 0 6px; }
  .trio-col p.desc { font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.82rem; color: var(--ink-soft); margin: 0; }

  .voices .cover {
    aspect-ratio: 16 / 10; background: linear-gradient(150deg, #dcd3bd, #c9bd9f);
    display: flex; align-items: center; justify-content: center;
    font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.78rem; color: var(--ink-soft); margin-bottom: 16px;
  }

  @media (max-width: 900px) {
    .hero { aspect-ratio: 4 / 5; }
    .hero-text { padding: 4vh 6vw 5vh; }
    .hero-text h1, .hero-text p.lead { max-width: none; }
    .latest-grid { grid-template-columns: repeat(2, 1fr); }
    .trio { grid-template-columns: 1fr; gap: 44px; }
  }
</style>
