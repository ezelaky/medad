---
import { client, queries, imageUrl } from '../lib/sanity';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCoverCard from '../components/BookCoverCard.astro';

const bestsellers = await client.fetch(queries.bestsellerEntries);

const tabs = ['روايات', 'غير روائي', 'الأكثر مبيعًا للشباب'];

// listPublishedDate is the same across every entry in a given week's batch
// (set once per sync run — see scripts/sync-nyt-bestsellers.mjs), so any
// entry's value is the batch's date. No entries yet -> no date to show.
const latestPublishedDate = bestsellers[0]?.listPublishedDate;
const weekLabel = latestPublishedDate
  ? new Date(latestPublishedDate).toLocaleDateString('ar-EG', { day: 'numeric', month: 'long', year: 'numeric' })
  : '—';

// TODO: placeholder wording — swap for the exact required attribution text
// once developer.nytimes.com/attribution is confirmed (blocked from
// automated access; see project notes). Do not ship this line to production
// as-is.
const nytAttribution = 'المصدر: قائمة الأكثر مبيعًا لصحيفة نيويورك تايمز (النص النهائي بانتظار التأكيد)';
---

<BaseLayout title="الأكثر مبيعًا — مِداد" activeKey="bestsellers">

<p class="page-intro ui">قائمة مِداد الأسبوعية، مبنية على قائمة الأكثر مبيعًا الصادرة عن صحيفة نيويورك تايمز</p>

<div class="list-meta">
  <span>الأسبوع من <span class="week">{weekLabel}</span></span>
  <div class="tabs ui" id="categoryTabs">
    {tabs.map((tab, i) => <a href="#" data-category={tab} class={i === 0 ? 'active' : ''}>{tab}</a>)}
  </div>
</div>

<p class="nyt-attribution ui">
  <a href="https://www.nytimes.com/books/best-sellers/" target="_blank" rel="noopener noreferrer">{nytAttribution}</a>
</p>

<section class="bestseller-list" id="bestsellerList">
  {bestsellers.length > 0 ? bestsellers.map((entry: any) => (
    <BookCoverCard
      variant="rank"
      category={entry.listCategory}
      coverSrc={imageUrl(entry.coverImage, 320)}
      title={entry.titleArabic || entry.titleOriginal}
      titleArabic={entry.titleArabic}
      titleOriginal={entry.titleOriginal}
      rank={entry.rank}
      author={entry.author}
      publisher={entry.publisher}
      description={entry.description}
      trend={entry.trend}
      weeksOnList={entry.weeksOnList}
    />
  )) : <p class="ui">لا يوجد قائمة منشورة بعد.</p>}

  <p class="ui empty-category" id="emptyCategoryMsg" hidden>لا يوجد كتب في هذا التصنيف بعد.</p>

  <div class="archive-link"><a href="#">قوائم الأسابيع السابقة ←</a></div>
</section>

<script>
  // Static build fetches every bestsellerEntry once (see queries.bestsellerEntries
  // in src/lib/sanity.ts) — there's no per-request server to re-query, so
  // switching tabs filters the already-rendered cards client-side by their
  // data-category attribute (set in BookCoverCard.astro) rather than
  // re-fetching anything.
  const tabsEl = document.getElementById('categoryTabs');
  const cards = Array.from(document.querySelectorAll('#bestsellerList .rank-card')) as HTMLElement[];
  const emptyMsg = document.getElementById('emptyCategoryMsg');

  function applyFilter(category: string) {
    let visibleCount = 0;
    for (const card of cards) {
      const matches = card.dataset.category === category;
      card.hidden = !matches;
      if (matches) visibleCount++;
    }
    if (emptyMsg) emptyMsg.hidden = visibleCount > 0;
  }

  tabsEl?.addEventListener('click', (e) => {
    const tab = (e.target as HTMLElement).closest('a[data-category]') as HTMLAnchorElement | null;
    if (!tab) return;
    e.preventDefault();
    tabsEl.querySelectorAll('a').forEach((a) => a.classList.remove('active'));
    tab.classList.add('active');
    applyFilter(tab.dataset.category!);
  });

  const initialTab = tabsEl?.querySelector('a.active') as HTMLAnchorElement | null;
  if (initialTab?.dataset.category) applyFilter(initialTab.dataset.category);
</script>

</BaseLayout>

<style>
  .list-meta {
    max-width: 800px; margin: 0 auto 5vh; padding: 0 6vw;
    display: flex; align-items: center; justify-content: center; gap: 16px;
    font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.85rem; color: var(--ink-soft);
  }
  .list-meta .week { color: var(--ink); font-weight: 600; }
  .tabs { display: flex; gap: 8px; }
  .tabs a {
    text-decoration: none; padding: 7px 16px; border-radius: 20px; border: 1px solid var(--line); color: var(--ink-soft); font-size: 0.82rem;
  }
  .tabs a.active { background: var(--ink); color: var(--paper); border-color: var(--ink); }

  .nyt-attribution {
    max-width: 1200px; margin: 0 auto 3vh; padding: 0 6vw;
    text-align: center; font-size: 0.78rem;
  }
  .nyt-attribution a { color: var(--ink-soft); text-decoration: none; border-bottom: 1px solid var(--line); }
  .nyt-attribution a:hover { color: var(--crimson); border-color: var(--crimson); }

  .bestseller-list {
    max-width: 1200px; margin: 0 auto; padding: 0 6vw 10vh;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }

  .empty-category { grid-column: 1 / -1; text-align: center; color: var(--ink-soft); }

  .archive-link { grid-column: 1 / -1; text-align: center; margin-top: 20px; }
  .archive-link a { font-family: 'IBM Plex Sans Arabic', sans-serif; color: var(--ink-soft); font-size: 0.85rem; text-decoration: none; border-bottom: 1px solid var(--line); }
  .archive-link a:hover { color: var(--crimson); border-color: var(--crimson); }

  @media (max-width: 900px) {
    .bestseller-list { grid-template-columns: 1fr; }
  }

  @media (max-width: 700px) {
    .list-meta { flex-direction: column; gap: 14px; }
  }
</style>
