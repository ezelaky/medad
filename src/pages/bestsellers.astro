---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCoverCard from '../components/BookCoverCard.astro';

const settings = await getEntry('siteSettings', 'singleton');
const bestsellers = (await getCollection('bestsellerEntry')).sort((a, b) => a.data.rank - b.data.rank);

const tabs = ['روايات', 'غير روائي', 'الأكثر مبيعًا للشباب'];
---

<BaseLayout title="الأكثر مبيعًا — مِداد" activeKey="bestsellers">

<p class="page-intro ui">قائمة مِداد الأسبوعية، معتمدة على بيانات المبيعات من شبكة من المكتبات والمنصات العربية والأجنبية</p>

<div class="list-meta">
  <span>الأسبوع من <span class="week">{settings?.data.bestsellersWeekOf}</span></span>
  <div class="tabs ui">
    {tabs.map((tab) => <a href="#" class={tab === 'روايات' ? 'active' : ''}>{tab}</a>)}
  </div>
</div>

<section class="bestseller-list">
  {bestsellers.map((entry) => (
    <BookCoverCard
      variant="rank"
      coverSrc={entry.data.coverImage}
      title={entry.data.bookTitle}
      rank={entry.data.rank}
      author={entry.data.author}
      publisher={entry.data.publisher}
      trend={entry.data.trend}
      weeksOnList={entry.data.weeksOnList}
    />
  ))}

  <div class="archive-link"><a href="#">قوائم الأسابيع السابقة ←</a></div>
</section>

</BaseLayout>

<style>
  .list-meta {
    max-width: 800px; margin: 0 auto 5vh; padding: 0 6vw;
    display: flex; align-items: center; justify-content: center; gap: 16px;
    font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.85rem; color: var(--ink-soft);
  }
  .list-meta .week { color: var(--ink); font-weight: 600; }
  .tabs { display: flex; gap: 8px; }
  .tabs a {
    text-decoration: none; padding: 7px 16px; border-radius: 20px; border: 1px solid var(--line); color: var(--ink-soft); font-size: 0.82rem;
  }
  .tabs a.active { background: var(--ink); color: var(--paper); border-color: var(--ink); }

  .bestseller-list { max-width: 800px; margin: 0 auto; padding: 0 6vw 10vh; }
  .bestseller-list :global(.rank-row:first-child) { border-top: 1px solid var(--ink); }

  .archive-link { text-align: center; margin-top: 40px; }
  .archive-link a { font-family: 'IBM Plex Sans Arabic', sans-serif; color: var(--ink-soft); font-size: 0.85rem; text-decoration: none; border-bottom: 1px solid var(--line); }
  .archive-link a:hover { color: var(--crimson); border-color: var(--crimson); }

  @media (max-width: 700px) {
    .list-meta { flex-direction: column; gap: 14px; }
  }
</style>
