---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="تواصل معنا — مِداد" description="تواصل مع فريق مِداد">

<article class="static-page">
  <h1 class="display-lg">تواصل معنا</h1>
  <p>لأي استفسار، اقتراح، أو ملاحظة حول محتوى مِداد، يسعدنا تواصلك مع فريق التحرير.</p>
  <p class="ui">
    <a href="mailto:info@midad.example">info@midad.example</a>
  </p>
</article>

</BaseLayout>

<style>
  .static-page { max-width: 680px; margin: 0 auto; padding: 8vh 6vw 10vh; font-size: 1.08rem; }
  .static-page h1 { font-size: clamp(1.9rem, 4vw, 2.6rem); margin: 0 0 32px; }
  .static-page p { margin: 0 0 24px; }
  .static-page a { color: var(--crimson); text-decoration: none; border-bottom: 1px solid var(--line); }
  .static-page a:hover { border-color: var(--crimson); }
</style>
