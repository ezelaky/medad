---
import { client, queries, imageUrl } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCoverCard from '../../components/BookCoverCard.astro';
import RedactedVerdict from '../../components/RedactedVerdict.astro';

export async function getStaticPaths() {
  const entries = await client.fetch(queries.bannedBookEntries);
  return entries.map((entry: any) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const others = (await client.fetch(queries.bannedBookEntries))
  .filter((e: any) => e.id !== entry.id)
  .slice(0, 4);
---

<BaseLayout title={`${entry.bookTitle} — أرشيف الكتب الممنوعة — مِداد`} description={entry.summary} activeKey="banned">

<section class="featured">
  <div class="cover">
    {entry.coverImage && <img src={imageUrl(entry.coverImage, 700)} alt="" />}
    <div class="badge"><span class="yr">{entry.year}</span><span class="place">{entry.country}</span></div>
  </div>
  <div class="content">
    <h1 class="display-lg">{entry.bookTitle}</h1>
    <p class="lead">{entry.summary}</p>
    <RedactedVerdict text={entry.officialReason} />
  </div>
</section>

{others.length > 0 && (
  <section class="browse">
    <div class="section-head">
      <h2 class="display-lg">من الأرشيف أيضًا</h2>
    </div>
    <div class="browse-grid">
      {others.map((other: any) => (
        <BookCoverCard
          variant="browse"
          href={`/banned-books/${other.id}/`}
          coverSrc={imageUrl(other.coverImage, 400)}
          title={other.bookTitle}
          tagText={`${other.year} — ${other.country}`}
        />
      ))}
    </div>
  </section>
)}

</BaseLayout>

<style>
  .featured { max-width: 1200px; margin: 6vh auto 8vh; padding: 0 6vw; display: flex; gap: 44px; align-items: flex-start; }
  .featured .cover {
    flex: 0 0 34%; aspect-ratio: 3 / 4; border-radius: 2px; position: relative; overflow: hidden;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
    display: flex; align-items: center; justify-content: center;
  }
  .featured .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .featured .cover .badge {
    position: absolute; bottom: 0; right: 0; left: 0;
    background: linear-gradient(to top, rgba(23, 21, 18, 0.82), transparent);
    color: var(--paper); padding: 20px 16px 12px; text-align: right;
    font-family: 'IBM Plex Sans Arabic', sans-serif;
  }
  .featured .cover .badge .yr { display: block; font-size: 1rem; font-weight: 600; }
  .featured .cover .badge .place { display: block; font-size: 0.75rem; opacity: 0.85; margin-top: 2px; }
  .featured .content { flex: 1; }
  .featured h1 { font-size: clamp(1.7rem, 2.8vw, 2.3rem); margin: 0 0 16px; line-height: 1.5; }
  .featured p.lead { color: var(--ink-soft); font-size: 1.05rem; margin: 0 0 8px; }

  .browse { max-width: 1200px; margin: 0 auto 10vh; padding: 0 6vw; }
  .browse .section-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--ink); padding-bottom: 14px; margin-bottom: 32px; }
  .browse .section-head h2 { font-size: 1.3rem; margin: 0; }
  .browse-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }

  @media (max-width: 700px) {
    .featured { flex-direction: column; }
    .featured .cover { flex: none; width: 100%; }
    .browse-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
