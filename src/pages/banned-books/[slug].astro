---
import { client, queries, imageUrl } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCoverCard from '../../components/BookCoverCard.astro';
import RedactedVerdict from '../../components/RedactedVerdict.astro';
import { renderPortableText } from '../../lib/portableText';

export async function getStaticPaths() {
  // bannedBookEntries (the archive-grid list query) deliberately stays lean
  // — it also powers the "others" sidebar below and the archive page
  // itself, neither of which needs body's Portable Text content. Each
  // page's own props come from bannedBookBySlug instead, same split
  // interviews/[slug].astro already uses for the same reason.
  const list = await client.fetch(queries.bannedBookEntries);
  const entries = await Promise.all(
    list.map((e: any) => client.fetch(queries.bannedBookBySlug, { slug: e.id }))
  );
  return entries.map((entry: any) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const others = (await client.fetch(queries.bannedBookEntries))
  .filter((e: any) => e.id !== entry.id)
  .slice(0, 4);
---

<BaseLayout title={`${entry.bookTitle} — أرشيف الكتب الممنوعة — مِداد`} description={entry.summary} activeKey="banned">

<section class="hero">
  {entry.coverImage ? (
    <img class="cover-image" src={imageUrl(entry.coverImage, 1600)} alt="" />
  ) : (
    <div class="cover-placeholder ui">صورة</div>
  )}
  <div class="scrim"></div>
  <div class="hero-text">
    <div class="meta-row ui">
      <span class="country">{entry.country}</span>
      {entry.year && <span class="year">{entry.year}</span>}
    </div>
    <h1 class="display-lg">{entry.bookTitle}</h1>
  </div>
</section>

<div class="article-content">
  {entry.author && <p class="byline display-sm">{entry.author}</p>}

  {entry.body?.length > 0 && (
    <div class="article-body">
      <div set:html={renderPortableText(entry.body)} />
    </div>
  )}

  <div class="ban-reason">
    <hr class="divider" />
    <p class="official-label ui">السجل الرسمي</p>
    <RedactedVerdict text={entry.officialReason} />
  </div>
</div>

{others.length > 0 && (
  <section class="browse">
    <div class="section-head">
      <h2 class="display-lg">من الأرشيف أيضًا</h2>
    </div>
    <div class="browse-grid">
      {others.map((other: any) => (
        <BookCoverCard
          variant="browse"
          href={`/banned-books/${other.id}/`}
          coverSrc={imageUrl(other.coverImage, 400)}
          title={other.bookTitle}
          tagText={`${other.year} — ${other.country}`}
        />
      ))}
    </div>
  </section>
)}

</BaseLayout>

<style>
  /* ---- Header hero — same landscape treatment as the banned-books
     listing page's featured card (index.astro .featured-hero): fixed
     height, image as an absolute-positioned background, bottom scrim,
     overlaid text. Author is deliberately excluded from the overlay
     (see .article-content .byline below) — it reads as the article's
     byline, not part of the hero graphic. */
  .hero {
    position: relative; display: block;
    max-width: 1200px; margin: 4vh auto 0;
    height: 460px; border-radius: 4px; overflow: hidden;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
  }
  .hero .cover-image {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center top; display: block;
  }
  .hero .cover-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; color: var(--ink-soft);
  }
  .hero .scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(23, 20, 15, 0.85) 0%,
      rgba(23, 20, 15, 0.4) 50%,
      rgba(23, 20, 15, 0) 100%
    );
  }
  .hero .hero-text {
    position: absolute; inset: auto 0 0 0;
    padding: 2rem; text-align: right;
  }
  .hero .meta-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: 10px; }
  .hero .meta-row .country { color: var(--crimson); font-size: 0.85rem; font-weight: 600; }
  .hero .meta-row .year { color: var(--paper); font-size: 0.82rem; opacity: 0.85; }
  .hero h1 {
    color: var(--paper); font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.5;
    margin: 0; max-width: 720px;
  }

  @media (max-width: 768px) {
    .hero h1 { font-family: 'Markazi Text', serif; font-size: 2rem; line-height: 1.4; }
  }

  /* ---- Below the hero — author, body, ban reason all share one column.
     Astro scopes this per-page automatically, so 800px only affects this
     page — interviews/[slug].astro and reads/[slug].astro each have their
     own separately-scoped .article-body rule (720px/680px) that this
     doesn't touch. Wider here specifically because this page's body
     content tends to run longer once an entry has one. */
  .article-content { max-width: 800px; margin: 0 auto; padding: 5vh 6vw 8vh; }
  .article-content .byline { font-size: 1.4rem; font-weight: 700; color: var(--ink); margin: 0 0 2rem; }

  .article-body { font-size: 1.08rem; }
  .article-body :global(p) { margin: 0 0 28px; }

  /* the ban reason now sits at the end of the article (after the body)
     instead of right below the author — the divider + label signal that
     shift from narrative body to official record. */
  .ban-reason .divider { border: none; border-top: 1px solid var(--ink); opacity: 0.15; margin: 3rem 0 2rem; }
  .ban-reason .official-label { color: var(--crimson); font-size: 0.85rem; margin: 0 0 4px; }

  /* placed after the base .article-content rule (not grouped with the
     .hero h1 768px block above) so equal-specificity cascade actually
     lets this win at narrow widths — an earlier version of this rule
     sat before the base rule in source order and silently lost to it. */
  @media (max-width: 768px) {
    .article-content { padding: 4vh 1.25rem 5vh; }
  }

  .browse { max-width: 1200px; margin: 0 auto 10vh; padding: 0 6vw; }
  .browse .section-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--ink); padding-bottom: 14px; margin-bottom: 32px; }
  .browse .section-head h2 { font-size: 1.3rem; margin: 0; }
  .browse-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }

  @media (max-width: 700px) {
    .hero { height: 300px; }
    .hero .hero-text { padding: 1.25rem; }
    .browse-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
