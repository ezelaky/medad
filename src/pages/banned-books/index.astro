---
import { client, queries, imageUrl } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await client.fetch(queries.bannedBookArchive);
const featured = entries[0] ?? null;
const olderEntries = entries.slice(1);
---

<BaseLayout title="أرشيف الكتب الممنوعة — مِداد" activeKey="banned">

<p class="page-intro ui">كتب حاول البعض إسكاتها عبر التاريخ. نحكي متى، ومَن قرر، ولماذا — وأين وصل الكتاب اليوم.</p>

{featured ? (
  <a class="featured-hero" href={`/banned-books/${featured.slug.current}/`}>
    {featured.coverImage ? (
      <img class="cover-image" src={imageUrl(featured.coverImage, 1400)} alt="" />
    ) : (
      <div class="cover-placeholder ui">صورة</div>
    )}
    <div class="scrim"></div>
    <div class="text">
      <div class="meta-row ui">
        <span class="country">{featured.country}</span>
        {featured.year && <span class="year">{featured.year}</span>}
      </div>
      <h2 class="display-lg">{featured.bookTitle}</h2>
      {featured.author && <p class="author ui">{featured.author}</p>}
    </div>
  </a>
) : (
  <p class="page-intro ui">لا يوجد كتب ممنوعة منشورة بعد.</p>
)}

{olderEntries.length > 0 && (
  <section class="older">
    <div class="section-head">
      <h2 class="display-lg">إصدارات سابقة</h2>
    </div>
    <div class="older-list">
      {olderEntries.map((entry: any) => (
        <div class="older-card">
          <a class="cover" href={`/banned-books/${entry.slug.current}/`}>
            {entry.coverImage && <img src={imageUrl(entry.coverImage, 240)} alt="" />}
          </a>
          <div class="content">
            <div class="meta-row ui">
              <span class="country">{entry.country}</span>
              {entry.year && <span class="year">{entry.year}</span>}
            </div>
            <a href={`/banned-books/${entry.slug.current}/`}>
              <h3 class="display-sm">{entry.bookTitle}</h3>
            </a>
            {entry.author && <p class="author ui">{entry.author}</p>}
          </div>
        </div>
      ))}
    </div>
  </section>
)}

</BaseLayout>

<style>
  /* ---- Featured entry — landscape hero, same scrim/overlay pattern as
     the homepage hero (index.astro .hero/.hero-scrim/.hero-text), but
     with a fixed height instead of aspect-ratio and hardcoded scrim
     stops instead of the homepage's per-slide --scrim-opacity, since
     this card doesn't have a "strength" setting from the CMS. */
  .featured-hero {
    position: relative; display: block;
    max-width: 1200px; margin: 0 auto 3rem;
    height: 420px; border-radius: 4px; overflow: hidden;
    text-decoration: none; color: inherit;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
  }
  .featured-hero .cover-image {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center top; display: block;
  }
  .featured-hero .cover-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; color: var(--ink-soft);
  }
  .featured-hero .scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(23, 20, 15, 0.85) 0%,
      rgba(23, 20, 15, 0.4) 50%,
      rgba(23, 20, 15, 0) 100%
    );
  }
  .featured-hero .text {
    position: absolute; inset: auto 0 0 0;
    padding: 2rem; text-align: right;
  }
  /* meta-row/country/year base rules are shared with .older-card below —
     this only overrides spacing and the year color, since the hero sits
     on a dark scrim (needs paper/white) while the older cards sit on a
     plain card background (needs ink-soft). */
  .featured-hero .meta-row { margin-bottom: 10px; }
  .featured-hero .meta-row .year { color: var(--paper); opacity: 0.85; }
  .featured-hero h2 {
    color: var(--paper); font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.5;
    margin: 0 0 8px; max-width: 720px; transition: opacity 0.2s ease;
  }
  .featured-hero:hover h2 { text-decoration: underline; opacity: 0.9; }
  .featured-hero .author { color: var(--paper); opacity: 0.85; font-size: 0.85rem; margin: 0; }

  /* Aref Ruqaa -> Markazi Text under 768px, same breakpoint and values as
     article headlines (interviews/[slug].astro, reads/[slug].astro) */
  @media (max-width: 768px) {
    .featured-hero h2 { font-family: 'Markazi Text', serif; font-size: 2rem; line-height: 1.4; }
  }

  /* shared by .featured-hero .meta-row and .older-card .meta-row */
  .meta-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: 14px; }
  .meta-row .country { color: var(--crimson); font-size: 0.85rem; font-weight: 600; }
  .meta-row .year { color: var(--ink-soft); font-size: 0.82rem; }

  /* ---- Older entries ---- */
  .older { max-width: 1200px; margin: 0 auto; padding: 0 6vw 10vh; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--ink); padding-bottom: 14px; margin-bottom: 32px; }
  .section-head h2 { font-size: 1.3rem; margin: 0; }

  .older-list { display: flex; flex-direction: column; gap: 18px; }
  .older-card {
    display: flex; gap: 20px;
    background: var(--card);
    border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    border-radius: 4px;
    padding: 14px;
  }
  .older-card .cover {
    flex: 0 0 120px; aspect-ratio: 3 / 4; border-radius: 2px; overflow: hidden; display: block;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba);
  }
  .older-card .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .older-card .content { flex: 1; min-width: 0; }
  .older-card .meta-row { margin-bottom: 8px; }
  .older-card .meta-row .country { font-size: 0.78rem; }
  .older-card .content > a { text-decoration: none; color: inherit; }
  .older-card h3 { font-size: 1.1rem; margin: 0 0 6px; line-height: 1.4; }
  .older-card .content > a:hover h3 { text-decoration: underline; }
  .older-card .author { color: var(--ink-soft); font-size: 0.82rem; margin: 0; }

  @media (max-width: 700px) {
    .featured-hero { height: 280px; }
    .featured-hero .text { padding: 1.25rem; }
  }
</style>
