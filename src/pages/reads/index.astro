---
import { client, queries, imageUrl } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const longReads = (await client.fetch(queries.longReads)).sort(
  (a: any, b: any) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
---

<BaseLayout title="ملفات — مِداد" activeKey="reads">

<p class="page-intro ui">قراءات مطوّلة وملفات خاصة في صناعة النشر والأدب العربي</p>

<section class="reads-section">
  <div class="reads-grid">
    {longReads.length > 0 ? longReads.map((entry: any) => (
      <ArticleCard
        variant="news"
        href={`/reads/${entry.id}/`}
        coverSrc={imageUrl(entry.coverImage, 500)}
        coverPlaceholder="صورة"
        title={entry.title}
        meta={`${entry.readingTime} — ${entry.author}`}
      />
    )) : <p class="ui">لا يوجد ملفات منشورة بعد.</p>}
  </div>
</section>

</BaseLayout>

<style>
  .reads-section { max-width: 1200px; margin: 0 auto; padding: 0 6vw 10vh; }
  .reads-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  @media (max-width: 900px) {
    .reads-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .reads-grid { grid-template-columns: 1fr; }
  }
</style>
