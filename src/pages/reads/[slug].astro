---
import { client, queries, imageUrl } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { formatArabicDate } from '../../lib/formatDate';
import { renderPortableText } from '../../lib/portableText';

export async function getStaticPaths() {
  const list = await client.fetch(queries.longReads);
  const entries = await Promise.all(
    list.map((r: any) => client.fetch(queries.longReadBySlug, { slug: r.id }))
  );
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const others = (await client.fetch(queries.longReads))
  .filter((r: any) => r.id !== entry.id)
  .sort((a: any, b: any) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime())
  .slice(0, 3);
---

<BaseLayout title={`${entry.title} — مِداد`} description={entry.dek} activeKey="reads">

<article>
  <div class="article-head">
    <div class="eyebrow ui">ملف خاص — قراءات مطوّلة</div>
    <h1 class="display-lg">{entry.title}</h1>
    <p class="dek">{entry.dek}</p>
    <div class="byline ui">
      <span>بقلم {entry.author}</span>
      <span class="author-dot"></span>
      <span>{entry.readingTime}</span>
      <span class="author-dot"></span>
      <span>{formatArabicDate(new Date(entry.publishedAt))}</span>
    </div>
  </div>

  <div class="article-cover">
    <div class="frame ui">{entry.coverImage ? <img src={imageUrl(entry.coverImage, 1200)} alt="" /> : 'الصورة الرئيسية للمقال'}</div>
  </div>
  <div class="cover-caption ui">تصوير توضيحي — مِداد</div>

  <div class="article-body">
    {entry.body?.length > 0 && <div set:html={renderPortableText(entry.body)} />}

    {entry.tags?.length > 0 && (
      <div class="tags">
        {entry.tags.map((tag: string) => <span class="tag ui">{tag}</span>)}
      </div>
    )}
  </div>
</article>

{others.length > 0 && (
  <section class="related">
    <h2 class="display-lg">مقالات ذات صلة</h2>
    <div class="related-grid">
      {others.map((other: any) => (
        <ArticleCard
          variant="news"
          href={`/reads/${other.id}/`}
          coverSrc={imageUrl(other.coverImage, 500)}
          coverPlaceholder="صورة"
          title={other.title}
          meta={`قراءات مطوّلة — ${formatArabicDate(new Date(other.publishedAt))}`}
        />
      ))}
    </div>
  </section>
)}

</BaseLayout>

<style>
  .article-head { max-width: 760px; margin: 0 auto; padding: 7vh 6vw 4vh; text-align: center; }
  .eyebrow { font-size: 0.8rem; color: var(--brass); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; }
  .article-head h1 { font-size: clamp(1.9rem, 4vw, 2.8rem); margin: 0 0 20px; line-height: 1.5; }
  .article-head .dek { color: var(--ink-soft); font-size: 1.08rem; margin: 0 0 26px; }
  .byline { font-size: 0.85rem; color: var(--ink-soft); display: flex; align-items: center; justify-content: center; gap: 10px; }
  .byline .author-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--brass); }

  .article-cover { max-width: 1100px; margin: 0 auto 6vh; padding: 0 6vw; }
  .article-cover .frame {
    aspect-ratio: 16 / 8; border-radius: 2px; overflow: hidden;
    background: linear-gradient(155deg, #dcd3bd, #c9bd9f);
    display: flex; align-items: center; justify-content: center;
    color: var(--ink-soft); font-size: 0.85rem;
  }
  .article-cover .frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cover-caption { font-size: 0.78rem; color: var(--ink-soft); text-align: center; margin-top: 10px; }

  .article-body { max-width: 680px; margin: 0 auto; padding: 0 6vw 8vh; font-size: 1.08rem; }
  .article-body :global(p) { margin: 0 0 28px; }
  .article-body :global(h2) { font-size: 1.4rem; margin: 48px 0 22px; }

  .tags { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
  .tags .tag {
    font-size: 0.78rem; color: var(--ink-soft);
    background: var(--card); border: 1px solid var(--line); padding: 6px 14px; border-radius: 20px;
  }

  .related { max-width: 1100px; margin: 0 auto; padding: 6vh 6vw 10vh; border-top: 1px solid var(--line); }
  .related h2 { font-size: 1.4rem; margin: 0 0 30px; }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  /* Aref Ruqaa's calligraphic strokes blur together below ~1.2rem (see
     global.css's .display-lg comment) — at tablet/mobile the headline sits
     well under its desktop clamp() size, so it switches to Markazi Text
     for legibility instead of shrinking Aref Ruqaa further. */
  @media (max-width: 768px) {
    .article-head h1 { font-family: 'Markazi Text', serif; font-size: 2rem; line-height: 1.4; }
  }

  @media (max-width: 700px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
