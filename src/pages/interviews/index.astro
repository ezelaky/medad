---
import { client, queries, imageUrl } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import InterviewCard from '../../components/InterviewCard.astro';
import { formatArabicDate } from '../../lib/formatDate';

const interviews = (await client.fetch(queries.interviews)).sort(
  (a: any, b: any) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
const featured = interviews.find((i: any) => i.featured) ?? interviews[0];
const rest = featured ? interviews.filter((i: any) => i.id !== featured.id) : [];
---

<BaseLayout title="حوارات — مِداد" activeKey="interviews">

<p class="page-intro ui">أحاديث مطوّلة مع كتّاب وناشرين ومترجمين، عن كواليس وأحوال عالم الكتابة والنشر</p>

{featured ? (
  <section class="featured">
    <a class="portrait ui" href={`/interviews/${featured.id}/`}>
      {featured.portraitImage ? <img src={imageUrl(featured.portraitImage, 700)} alt="" /> : 'صورة الضيف'}
    </a>
    <div class="content">
      <div class="subject ui">حوار مع {featured.guestRole}</div>
      <a href={`/interviews/${featured.id}/`}><h2 class="display-lg">{featured.title}</h2></a>
      <p class="lead">{featured.excerpt}</p>
      <div class="byline ui">حوارات — {formatArabicDate(new Date(featured.publishedAt))}</div>
    </div>
  </section>
) : (
  <p class="page-intro ui">لا يوجد حوارات منشورة بعد.</p>
)}

{rest.length > 0 && (
  <section class="interviews-section">
    <div class="section-head">
      <h2 class="display-lg">حوارات سابقة</h2>
    </div>
    <div class="interviews-grid">
      {rest.map((interview: any) => (
        <InterviewCard
          href={`/interviews/${interview.id}/`}
          portraitSrc={imageUrl(interview.portraitImage, 500)}
          subject={`حوار مع ${interview.guestRole}`}
          title={interview.title}
          meta={formatArabicDate(new Date(interview.publishedAt))}
        />
      ))}
    </div>
  </section>
)}

</BaseLayout>

<style>
  .featured { max-width: 1100px; margin: 0 auto 8vh; padding: 0 6vw; display: flex; gap: 44px; align-items: center; }
  .featured .portrait {
    flex: 0 0 320px; aspect-ratio: 3 / 4; border-radius: 2px; overflow: hidden;
    background: linear-gradient(160deg, #e7e0d1, #d8cfba); display: flex; align-items: center; justify-content: center;
    color: var(--ink-soft); font-size: 0.8rem; text-decoration: none;
  }
  .featured .portrait img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .featured .content { flex: 1; }
  .featured .content > a { text-decoration: none; color: inherit; }
  .featured .subject { font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.85rem; color: var(--crimson); margin-bottom: 10px; }
  .featured h2 { font-size: clamp(1.5rem, 2.6vw, 2.1rem); margin: 0 0 16px; line-height: 1.5; }
  .featured p.lead { color: var(--ink-soft); font-size: 1.02rem; margin: 0 0 14px; }
  .featured .byline { font-family: 'IBM Plex Sans Arabic', sans-serif; font-size: 0.8rem; color: var(--brass); }

  .interviews-section { max-width: 1100px; margin: 0 auto; padding: 0 6vw 8vh; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--ink); padding-bottom: 14px; margin-bottom: 32px; }
  .section-head h2 { font-size: 1.3rem; margin: 0; }
  .interviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }

  @media (max-width: 900px) {
    .featured { flex-direction: column; }
    .featured .portrait { flex: none; width: 100%; max-width: 320px; }
    .interviews-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
