---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import InterviewCard from '../../components/InterviewCard.astro';
import { formatArabicDate } from '../../lib/formatDate';

export async function getStaticPaths() {
  const interviews = await getCollection('interview');
  return interviews.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const others = (await getCollection('interview'))
  .filter((i) => i.id !== entry.id)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<BaseLayout title={`${entry.data.title} — مِداد`} description={entry.data.excerpt} activeKey="interviews">

<article>
  <div class="article-head">
    <div class="eyebrow ui">حوار مع {entry.data.guestRole}</div>
    <h1 class="display">{entry.data.title}</h1>
    <p class="dek">{entry.data.excerpt}</p>
    <div class="byline ui">
      <span>{entry.data.guestName}</span>
      <span class="author-dot"></span>
      <span>{formatArabicDate(entry.data.publishedAt)}</span>
    </div>
  </div>

  {entry.data.portraitImage && (
    <div class="article-cover">
      <div class="frame"><img src={entry.data.portraitImage} alt="" /></div>
    </div>
  )}

  <div class="article-body">
    <Content />
  </div>
</article>

{others.length > 0 && (
  <section class="related">
    <h2 class="display">حوارات أخرى</h2>
    <div class="related-grid">
      {others.map((other) => (
        <InterviewCard
          href={`/interviews/${other.id}/`}
          portraitSrc={other.data.portraitImage}
          subject={`حوار مع ${other.data.guestRole}`}
          title={other.data.title}
          meta={formatArabicDate(other.data.publishedAt)}
        />
      ))}
    </div>
  </section>
)}

</BaseLayout>

<style>
  .article-head { max-width: 760px; margin: 0 auto; padding: 7vh 6vw 4vh; text-align: center; }
  .eyebrow { font-size: 0.8rem; color: var(--brass); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; }
  .article-head h1 { font-size: clamp(1.9rem, 4vw, 2.8rem); margin: 0 0 20px; line-height: 1.5; }
  .article-head .dek { color: var(--ink-soft); font-size: 1.08rem; margin: 0 0 26px; }
  .byline { font-size: 0.85rem; color: var(--ink-soft); display: flex; align-items: center; justify-content: center; gap: 10px; }
  .byline .author-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--brass); }

  .article-cover { max-width: 700px; margin: 0 auto 6vh; padding: 0 6vw; }
  .article-cover .frame {
    aspect-ratio: 3 / 4; max-width: 320px; margin: 0 auto; border-radius: 2px; overflow: hidden;
    background: linear-gradient(155deg, #dcd3bd, #c9bd9f);
    display: flex; align-items: center; justify-content: center;
  }
  .article-cover .frame img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .article-body { max-width: 680px; margin: 0 auto; padding: 0 6vw 8vh; font-size: 1.08rem; }
  .article-body :global(p) { margin: 0 0 28px; }

  .related { max-width: 1100px; margin: 0 auto; padding: 6vh 6vw 10vh; border-top: 1px solid var(--line); }
  .related h2 { font-size: 1.4rem; margin: 0 0 30px; }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  @media (max-width: 700px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
