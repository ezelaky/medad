# Fill these in after creating the Sanity project (`npx sanity login`, then
# `npx sanity init` from the repo root — see sanity/README.md) and copy this
# file to .env. Until PUBLIC_SANITY_PROJECT_ID is set, the embedded Studio at
# /studio is skipped so `npm run dev` / `npm run build` keep working against
# the local content collections in src/content/.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2026-01-01

# Only needed to run `npm run sync:bestsellers` locally (scripts/sync-nyt-bestsellers.mjs).
# In CI these are set as GitHub Actions secrets instead — see
# .github/workflows/sync-bestsellers.yml. Never commit real values.
NYT_API_KEY=
SANITY_API_TOKEN=
